# Cisco Compliance Audit — credential environment variables
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed to version control.
#
# Variables already set in your shell environment always take precedence
# over values in this file.
#
# ── SSH credentials ───────────────────────────────────────────────────────────
SWITCH_USER=your_username
SWITCH_PASS=your_password

# ── Enable secret (optional) ─────────────────────────────────────────────────
# Set USE_ENABLE=true and supply a secret only if your devices require
# 'enable' to reach privileged EXEC mode.
USE_ENABLE=false
# ENABLE_SECRET=your_enable_secret
